# Three.dev API key (r3_sk_...) — used by the observability middleware to
# authenticate reporting calls to the Three.dev api3 service.
THREE_API_KEY=your-three-api-key-here

# Three.dev api3 base URL. Defaults to https://api.three.dev.
# Override only when pointing at a staging or local instance.
THREE_ENDPOINT=https://api.three.dev

# Long-term Bedrock API key — the primary auth method for direct Bedrock Runtime
# access. Obtain from the AWS Bedrock console. The SDK uses bearer token auth
# when this is set; AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY are not needed.
AWS_BEARER_TOKEN_BEDROCK=your-bedrock-api-key-here

# AWS region — required to construct the Bedrock Runtime endpoint URL
# (bedrock-runtime.{region}.amazonaws.com).
AWS_REGION=eu-central-1
