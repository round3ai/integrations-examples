# Three.dev API key (r3_sk_...) — authenticates reporting calls to the Three.dev
# api3 service. Sent as: Authorization: Bearer <THREE_API_KEY>.
THREE_API_KEY=your-three-api-key-here

# Three.dev use case identifier — must match the slug configured in the dashboard.
USE_CASE_SLUG=your-use-case-slug-here

# Three.dev api3 base URL. Defaults to https://api.three.dev.
# Override only when pointing at a staging or local instance.
THREE_ENDPOINT=https://api.three.dev

# Your Anthropic API key (sk-ant-...). Calls go DIRECTLY to Anthropic — Three.dev is
# not a proxy and never sees this key or your traffic.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Set to 1 to log api3 reporting status / errors to stderr (debugging only).
# THREE_DEBUG=1
