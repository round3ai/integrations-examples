# Three.dev API key (r3_sk_...). Used for BOTH:
#   - the Authorization: Bearer header on the api.three.dev control-plane calls
#     (/experiments/assign and /metrics/report), AND
#   - the apiKey on the OpenAI client pointed at the Three.dev gateway. The gateway
#     holds the real OpenAI provider credentials for your use case, so you do NOT
#     need a separate OPENAI_API_KEY.
THREE_API_KEY=your-three-api-key-here

# Three.dev use case slug — must match the use case configured in the dashboard.
# Sent as the X-Three-Use-Case header on gateway calls and in the assign/report bodies.
USE_CASE_SLUG=your-use-case-slug-here

# Metric slug reported once at the end of the conversation (the session's quality signal).
# Must match a metric configured for this use case in the dashboard.
METRIC_SLUG=response-quality

# Default model, used when /assign returns control (no active experiment). When /assign
# returns metadata.model, that value overrides this for the turn.
MODEL=gpt-5.4-mini

# Three.dev control-plane base URL (assign + metrics). Default: https://api.three.dev
# Override only when pointing at a staging or local instance.
THREE_API_ENDPOINT=https://api.three.dev

# Three.dev LLM gateway base URL (OpenAI-compatible). Default: https://gate.three.dev/v1
# This is the OpenAI client's baseURL — it MUST include the /v1 path segment (the SDK
# appends /chat/completions to it, just like the default https://api.openai.com/v1).
THREE_GATEWAY_URL=https://gate.three.dev/v1
