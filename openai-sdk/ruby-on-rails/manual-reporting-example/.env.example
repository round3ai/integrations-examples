# Three.dev API key (r3_sk_...) — authenticates reporting calls to api3.
# Sent as: Authorization: Bearer <THREE_API_KEY>.
THREE_API_KEY=your-three-api-key-here

# Three.dev use case identifier — must match the slug configured in the dashboard.
USE_CASE_SLUG=your-use-case-slug-here

# Three.dev api3 base URL. Defaults to https://api.three.dev.
THREE_ENDPOINT=https://api.three.dev

# Your OpenAI API key (sk-...). Calls go DIRECTLY to OpenAI — Three.dev is not a proxy
# and never sees this key or your traffic.
OPENAI_API_KEY=your-openai-api-key-here
